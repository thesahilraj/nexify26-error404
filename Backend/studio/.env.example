# ========================================
# DrFarm Environment Variables
# ========================================
# Copy this file to .env.local and fill in the values.
# These SAME variables must also be set in Vercel Environment Variables
# for production deployment to work.

# REQUIRED: Google Gemini API Key (server-side only)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# REQUIRED: WeatherAPI.com Key (server-side only)
# Get one at: https://www.weatherapi.com/my/
WEATHER_API_KEY="your-weather-api-key-here"

# Optional: Ollama URL for local AI chat (only works in development)
# OLLAMA_URL="http://127.0.0.1:11434"

# Optional: Firebase Admin SDK Credentials
# FIREBASE_PROJECT_ID="your-firebase-project-id"
# FIREBASE_CLIENT_EMAIL="your-firebase-client-email"
# FIREBASE_PRIVATE_KEY="your-firebase-private-key"
